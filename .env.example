# Local server
PORT=3000
HOST=0.0.0.0

# Data paths (optional)
# DATA_DIR=./data
# DB_PATH=./data/db.sqlite
# UPLOADS_DIR=./data/uploads

# Backup export token (set in production, keep secret)
# BACKUP_TOKEN=replace-with-a-long-random-value

# Optional: automatic monthly rotation seed
# If set, backup token rotates every month automatically.
# BACKUP_TOKEN_SEED=replace-with-a-long-random-seed
